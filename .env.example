# VulnScan Pro — Environment Variables (example)

# Flask
VULNSCAN_SECRET=replace-with-long-random-secret
VULNSCAN_COOKIE_SECURE=true
VULNSCAN_COOKIE_SAMESITE=Strict
VULNSCAN_SESSION_LIFETIME_HOURS=12
VULNSCAN_IDLE_TIMEOUT_SECONDS=900

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=replace-with-anon-key
SUPABASE_SERVICE_KEY=replace-with-service-role-key

# Mail
VULNSCAN_APP_URL=https://your-domain.example
VULNSCAN_SMTP_HOST=smtp.example.com
VULNSCAN_SMTP_PORT=587
VULNSCAN_SMTP_USER=your-user@example.com
VULNSCAN_SMTP_PASS=replace-with-app-password
